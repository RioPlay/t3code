{
  "schema_version": 3,
  "fork": "RioPlay/t3code",
  "integration_branch": "main",
  "completion_mode": "automated",
  "auto_continue": true,
  "require_merge_approval": false,
  "program_end_step": "s28",
  "stack_tool": "plain-git",
  "babysit_ci": true,
  "max_ci_retries_per_step": 3,
  "fault_tolerance_doc": "scratch/android-parity/FAULT-TOLERANCE.md",
  "tool_call_rules": {
    "no_claim_without_tool_result": true,
    "fail_closed_on_validate_plan": true,
    "fail_closed_on_gate_sh": true,
    "git_lock_retries": 3,
    "compaction_recovery": ["loop-state.json", "implementation.md current step block", "gh pr list"]
  },
  "gates": {
    "m0_staging": {
      "automated_unblock": "pass_ci",
      "production_unblock": "pass_device",
      "automated_step": "s09",
      "optional_device_step": "s09b"
    },
    "t3_complete": {
      "automated_unblock": "pass_ci",
      "production_unblock": "pass_device",
      "automated_step": "s27",
      "optional_device_step": "s27b"
    }
  },
  "pinned_decisions": {
    "completion": "automated mode: CI+integration proof unblocks; device gates optional (s09b, s27b)",
    "ios_regression": "gate.sh FORCE_* on apps/mobile touches",
    "out_of_scope": "mirror composer, Ghostty NDK, M4 FGS/widgets"
  }
}
